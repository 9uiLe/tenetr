{
  "name": "tenetr",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.4.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:contract": "vitest run --project contract",
    "test:golden": "vitest run --project golden",
    "lint": "biome check .",
    "check": "pnpm build && pnpm lint && pnpm check:egress && pnpm -r run codegen:check && pnpm test",
    "check:egress": "node scripts/check-egress-boundary.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.5",
    "@types/node": "26.1.1",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  }
}
