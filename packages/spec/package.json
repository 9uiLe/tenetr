{
  "name": "@tenetr/spec",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "schemas"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "codegen": "node scripts/generate-types.mjs",
    "codegen:check": "node scripts/generate-types.mjs --check"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "26.1.1",
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1",
    "json-schema-to-typescript": "15.0.4",
    "yaml": "2.9.0"
  }
}
