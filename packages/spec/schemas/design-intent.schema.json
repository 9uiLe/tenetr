{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/9uiLe/tenetr/schemas/design-intent.schema.json",
  "title": "Design Intent Contract",
  "type": "object",
  "required": [
    "schema_version",
    "task",
    "classification",
    "applicable_principles",
    "referenced_exemplars",
    "unresolved_items",
    "acceptance_criteria",
    "ready_to_implement",
    "ready_blockers"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "string", "pattern": "^1\\.\\d+$" },
    "task": {
      "type": "object",
      "required": ["id", "description", "scenario"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
        "description": { "type": "string", "minLength": 1 },
        "scenario": { "type": "string", "minLength": 1 },
        "screen": { "type": "string" }
      }
    },
    "classification": {
      "enum": [
        "improve-existing-screen",
        "new-screen",
        "restructure",
        "unknown"
      ]
    },
    "applicable_principles": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "reason"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*\\.[a-z][a-z0-9-]*$"
          },
          "reason": { "type": "string", "minLength": 1 }
        }
      }
    },
    "referenced_exemplars": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "relation"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
          "relation": { "enum": ["follow", "avoid"] }
        }
      }
    },
    "tradeoff_resolutions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["tradeoff", "resolved_to", "reason"],
        "additionalProperties": false,
        "properties": {
          "tradeoff": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
          "resolved_to": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*\\.[a-z][a-z0-9-]*$"
          },
          "reason": { "type": "string", "minLength": 1 }
        }
      }
    },
    "unresolved_items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "question", "blocking"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
          "question": { "type": "string", "minLength": 1 },
          "blocking": { "type": "boolean" },
          "default_answer": { "type": "string" }
        }
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "constraints": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "ready_to_implement": { "type": "boolean" },
    "ready_blockers": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "ready_to_implement": { "const": true } },
        "required": ["ready_to_implement"]
      },
      "then": {
        "properties": {
          "applicable_principles": { "minItems": 1 },
          "acceptance_criteria": { "minItems": 1 },
          "ready_blockers": { "maxItems": 0 }
        }
      }
    },
    {
      "if": {
        "properties": { "ready_to_implement": { "const": false } },
        "required": ["ready_to_implement"]
      },
      "then": {
        "properties": {
          "ready_blockers": { "minItems": 1 }
        }
      }
    }
  ]
}
