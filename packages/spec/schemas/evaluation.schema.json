{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/9uiLe/tenetr/schemas/evaluation.schema.json",
  "title": "Evaluation Result",
  "type": "object",
  "required": ["schema_version", "run_id", "summary", "findings"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^1\\.\\d+$"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "object",
      "required": ["deterministic", "model", "human_review"],
      "additionalProperties": false,
      "properties": {
        "deterministic": {
          "type": "object",
          "required": ["pass", "fail"],
          "additionalProperties": false,
          "properties": {
            "pass": {
              "type": "integer",
              "minimum": 0
            },
            "fail": {
              "type": "integer",
              "minimum": 0
            },
            "unknown": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "model": {
          "type": "object",
          "required": ["pass", "warn"],
          "additionalProperties": false,
          "properties": {
            "pass": {
              "type": "integer",
              "minimum": 0
            },
            "warn": {
              "type": "integer",
              "minimum": 0
            },
            "unknown": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "human_review": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/finding"
      }
    }
  },
  "$defs": {
    "finding": {
      "type": "object",
      "required": [
        "id",
        "evaluator",
        "kind",
        "verdict",
        "observations",
        "judgment"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^finding-[a-z0-9-]+$"
        },
        "evaluator": {
          "type": "string",
          "minLength": 1
        },
        "principle": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*\\.[a-z][a-z0-9-]*$"
        },
        "check": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "kind": {
          "enum": ["deterministic", "model", "human"]
        },
        "verdict": {
          "enum": ["pass", "warn", "fail", "unknown", "human_review"]
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "observations": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["type", "fact"],
            "additionalProperties": false,
            "properties": {
              "type": {
                "enum": ["visual", "metadata", "code", "environment"]
              },
              "fact": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "judgment": {
          "type": "string",
          "minLength": 1
        },
        "remediation": {
          "type": "string"
        },
        "evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidence"
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "verdict": {
                "const": "fail"
              }
            },
            "required": ["verdict"]
          },
          "then": {
            "required": ["evidence"],
            "properties": {
              "evidence": {
                "minItems": 1
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "model"
              }
            },
            "required": ["kind"]
          },
          "then": {
            "required": ["confidence"],
            "properties": {
              "verdict": {
                "enum": ["pass", "warn", "unknown", "human_review"]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "verdict": {
                "enum": ["warn", "fail", "human_review"]
              }
            },
            "required": ["verdict"]
          },
          "then": {
            "properties": {
              "observations": {
                "minItems": 1
              }
            }
          }
        }
      ]
    },
    "evidence": {
      "type": "object",
      "required": ["type", "artifact"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "enum": ["image_region", "artifact", "metadata"]
        },
        "artifact": {
          "type": "string",
          "minLength": 1
        },
        "region": {
          "type": "object",
          "required": ["x", "y", "width", "height"],
          "additionalProperties": false,
          "properties": {
            "x": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "y": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "width": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "height": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            }
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "const": "image_region"
              }
            },
            "required": ["type"]
          },
          "then": {
            "required": ["region"]
          }
        }
      ]
    }
  }
}
