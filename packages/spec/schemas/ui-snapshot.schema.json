{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/9uiLe/tenetr/schemas/ui-snapshot.schema.json",
  "title": "UI Snapshot",
  "description": "Normalized accessibility/UI metadata captured for one screen state (§16.3). Coordinates are fractions of the screen (origin top-left, 0..1). Absence of an optional field means the source tool could not provide it (never encode unknown as false).",
  "type": "object",
  "required": ["schema_version", "scenario", "screen", "source", "elements"],
  "additionalProperties": false,
  "$defs": {
    "element": {
      "type": "object",
      "required": ["id", "role", "frame"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^el-[a-z0-9-]+$" },
        "role": {
          "enum": [
            "button",
            "text",
            "image",
            "toggle",
            "textfield",
            "container",
            "other"
          ]
        },
        "label": { "type": "string" },
        "identifier": { "type": "string" },
        "frame": {
          "type": "object",
          "required": ["x", "y", "width", "height"],
          "additionalProperties": false,
          "properties": {
            "x": { "type": "number", "minimum": 0, "maximum": 1 },
            "y": { "type": "number", "minimum": 0, "maximum": 1 },
            "width": { "type": "number", "minimum": 0, "maximum": 1 },
            "height": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        },
        "enabled": { "type": "boolean" },
        "hittable": { "type": "boolean" },
        "selected": { "type": "boolean" },
        "traits": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" }
        },
        "children": {
          "type": "array",
          "items": { "$ref": "#/$defs/element" }
        }
      }
    }
  },
  "properties": {
    "schema_version": { "type": "string", "pattern": "^1\\.\\d+$" },
    "scenario": { "type": "string", "minLength": 1 },
    "screen": {
      "type": "object",
      "required": ["width", "height"],
      "additionalProperties": false,
      "properties": {
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 },
        "scale": { "type": "number", "minimum": 1 }
      }
    },
    "source": {
      "type": "object",
      "required": ["tool", "raw_artifact"],
      "additionalProperties": false,
      "properties": {
        "tool": { "type": "string", "minLength": 1 },
        "tool_version": { "type": "string" },
        "raw_artifact": {
          "description": "Path of the preserved raw dump artifact this snapshot was normalized from; empty string when the tool emits normalized form natively.",
          "type": "string"
        }
      }
    },
    "elements": {
      "type": "array",
      "items": { "$ref": "#/$defs/element" }
    }
  }
}
